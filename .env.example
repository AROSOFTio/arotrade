# ============================================================================
# AroTrade AI - Environment Configuration Template
#
# SECURITY: NEVER commit .env to Git - it contains secrets!
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in YOUR values below
# 3. .env is in .gitignore - stays local/private
# 4. For Coolify: Add these as Environment Variables in UI
# ============================================================================

# Application
APP_NAME=AroTrade AI
APP_ENV=production
APP_URL=https://arotrade.aroftlabs.com
DEBUG=false

# ============================================================================
# DATABASE - PostgreSQL
# Replace with YOUR credentials
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=arotrade
POSTGRES_USER=AroTrader91
POSTGRES_PASSWORD=BenTech5428

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ============================================================================
# SECURITY - JWT & Encryption
# GENERATE NEW: openssl rand -hex 16 (for each)
# NEVER use default values below!
# ============================================================================
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS_USING_OPENSSL
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# AES-256 Encryption Key (32 characters)
# Generate: openssl rand -hex 16
ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHARS_USING_OPENSSL

# Security - Passwords
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# CORS & Security
ALLOWED_ORIGINS=https://arotrade.aroftlabs.com,http://localhost:3000
CORS_CREDENTIALS=true
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# AI PROVIDERS - Get Your API Keys
# ============================================================================

# Gemini API (Active)
# Get key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=CHANGE_ME_ADD_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# Future AI Providers (Commented - uncomment when adding support)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4-turbo
# GROQ_API_KEY=your_groq_key_here
# ANTHROPIC_API_KEY=your_claude_key_here
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# ============================================================================
# TRADING INTEGRATIONS
# ============================================================================

# Demo Trading (Paper Engine)
DEMO_INITIAL_BALANCE=10000
DEMO_ACCOUNT_CURRENCY=USD

# Deriv API (Demo)
DERIV_APP_ID=
DERIV_API_TOKEN_DEMO=
DERIV_API_TOKEN_LIVE=
DERIV_SERVER_URL=wss://ws.derivws.com/websockets/v3

# Future Broker Integrations (Commented)
# METAAPI_TOKEN=your_metaapi_token
# METAAPI_ACCOUNT_ID=
# OANDA_API_KEY=your_oanda_key
# OANDA_ACCOUNT_ID=
# CTRADER_CLIENT_ID=
# CTRADER_CLIENT_SECRET=
# CTRADER_ACCOUNT_ID=
# TRADINGVIEW_WEBHOOK_SECRET=your_webhook_secret

# ============================================================================
# CRITICAL TRADING CONTROLS
# ============================================================================

# NEVER enable live trading without explicit admin action and user consent
ENABLE_LIVE_TRADING=false

# Risk Parameters (Defaults)
DEFAULT_RISK_PER_TRADE=1.0
MAX_RISK_PER_TRADE=5.0
MAX_DAILY_LOSS_PERCENT=3.0
MAX_WEEKLY_LOSS_PERCENT=5.0
MAX_OPEN_TRADES=5
MAX_ACCOUNT_DRAWDOWN_PERCENT=25.0

# Strategy Validation
MIN_BACKTEST_TRADES=100
MIN_PROFIT_FACTOR=1.2
MAX_CONSECUTIVE_LOSSES=5
ALLOW_MARTINGALE=false

# ============================================================================
# EMAIL (Optional - for notifications)
# ============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@arotrade.com
SMTP_FROM_NAME=AroTrade AI

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# ============================================================================
# SERVICES
# ============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Frontend
NEXT_PUBLIC_API_URL=https://arotrade.aroftlabs.com/api
NEXT_PUBLIC_APP_NAME=AroTrade AI
NEXT_PUBLIC_BRAND_COLOR=#155DFC

# ============================================================================
# ADMIN USER
# After deployment, run: docker compose exec api python scripts/create_admin.py
# ============================================================================

# Default admin setup (create via CLI, not here)
ADMIN_EMAIL=admin@arotrade.com
# Admin password is set interactively during setup
# NEVER store here - it's in database as bcrypt hash

# Feature Flags
FEATURE_LIVE_TRADING=false
FEATURE_MT5_BRIDGE=false
FEATURE_SOCIAL_SIGNALS=false
FEATURE_AI_OPTIMIZATION=false

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
ANALYTICS_ENABLED=false

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================

BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# ============================================================================
# 🔐 SETUP INSTRUCTIONS FOR AROTRADE AI
# ============================================================================
#
# DOCKER COMPOSE (Local/VPS):
# 1. cp .env.example .env
# 2. nano .env (update values below)
# 3. docker compose up -d
#
# COOLIFY (Recommended for VPS):
# 1. Install Coolify on VPS
# 2. Connect GitHub repo: https://github.com/AROSOFTio/arotrade
# 3. In Coolify UI → Environment Variables, set:
#    - POSTGRES_USER=AroTrader91
#    - POSTGRES_PASSWORD=BenTech5428
#    - JWT_SECRET=<generate-with-openssl>
#    - ENCRYPTION_KEY=<generate-with-openssl>
#    - GEMINI_API_KEY=<your-gemini-key>
# 4. Deploy → Coolify handles everything
#
# GENERATE SECRETS (run locally):
# openssl rand -hex 16     # For JWT_SECRET & ENCRYPTION_KEY
#
# ⚠️  CRITICAL SECURITY RULES:
# - NEVER commit .env to Git (it's in .gitignore)
# - NEVER hardcode passwords in code
# - NEVER share .env file
# - USE unique passwords for each environment
# - ROTATE secrets regularly
# - All secrets MUST be 20+ characters minimum
#
# DEFAULT CREDENTIALS (Update these):
# Database User: AroTrader91
# Database Password: BenTech5428
# Admin Email: admin@arotrade.com (set via CLI after deploy)
# ============================================================================
