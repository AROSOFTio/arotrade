# ============================================================================
# AroTrade AI - Environment Configuration Template
#
# SECURITY: NEVER commit .env to Git - it contains secrets!
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Fill in YOUR values below
# 3. .env is in .gitignore - stays local/private
# 4. For Coolify: Add these as Environment Variables in UI
# ============================================================================

# Application
APP_NAME=AroTrade AI
APP_ENV=production
APP_URL=https://your-domain.com
DEBUG=false

# ============================================================================
# DATABASE - PostgreSQL
# ============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=arotrade
POSTGRES_USER=CHANGE_ME_DB_USER
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ============================================================================
# SECURITY - JWT & Encryption
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# NEVER use default values!
# ============================================================================
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_OR_PYTHON_SECRETS
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# AES-256 Encryption Key (32 characters)
# Generate: python3 -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_OPENSSL_OR_PYTHON_SECRETS

# Security - Passwords
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# CORS & Security
ALLOWED_ORIGINS=https://your-domain.com,http://localhost:3000
CORS_CREDENTIALS=true
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# AI PROVIDERS
# ============================================================================

# Gemini API
# Get key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=CHANGE_ME_ADD_YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-flash

# ============================================================================
# TRADING INTEGRATIONS
# ============================================================================

# MetaApi (MT4/MT5 connectivity)
# Get token: https://app.metaapi.cloud
METAAPI_TOKEN=CHANGE_ME_ADD_YOUR_METAAPI_TOKEN
METAAPI_REGION=london

# Deriv API (Only for users who actually trade on Deriv — not used for MT5)
# Leave empty if you are not using Deriv accounts
DERIV_APP_ID=
DERIV_API_TOKEN_DEMO=
DERIV_API_TOKEN_LIVE=

# ============================================================================
# CRITICAL TRADING CONTROLS
# ============================================================================

# NEVER enable live trading without explicit admin action and user consent
ENABLE_LIVE_TRADING=false

# Maximum volume per single live order (safety cap)
MAX_LIVE_ORDER_VOLUME=1.0

# Paper/Demo trading
PAPER_TRADING_ENABLED=true
DEMO_INITIAL_BALANCE=10000
DEMO_ACCOUNT_CURRENCY=USD

# ============================================================================
# AUTOMATIC SCANNER SETTINGS
# ============================================================================

# Enable the background market scanner
SCANNER_ENABLED=true
SCANNER_DEFAULT_INTERVAL_SECONDS=60

# Quote freshness — older quotes are rejected before execution
QUOTE_STALE_AFTER_SECONDS=10

# Entry-zone monitoring for approved signals
SIGNAL_ENTRY_MONITOR_ENABLED=true

# Minimum signal quality thresholds
SIGNAL_MIN_CONFIDENCE=70
SIGNAL_MIN_RISK_REWARD=1.5

# Market streaming via MetaApi
MARKET_STREAM_ENABLED=true

# Celery Beat scheduler
CELERY_BEAT_ENABLED=true

# ============================================================================
# RISK PARAMETERS
# ============================================================================

DEFAULT_RISK_PER_TRADE=1.0
MAX_RISK_PER_TRADE=5.0
MAX_DAILY_LOSS_PERCENT=3.0
MAX_WEEKLY_LOSS_PERCENT=5.0
MAX_OPEN_TRADES=5
MAX_ACCOUNT_DRAWDOWN_PERCENT=25.0

# Default for new scanner profiles
SCANNER_DEFAULT_RISK_PERCENT=0.5
SCANNER_DEFAULT_MAX_POSITIONS=1
SCANNER_DEFAULT_APPROVAL_REQUIRED=true

# Strategy Validation
MIN_BACKTEST_TRADES=100
MIN_PROFIT_FACTOR=1.2
MAX_CONSECUTIVE_LOSSES=5
ALLOW_MARTINGALE=false

# ============================================================================
# EMAIL (Optional - for notifications)
# ============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_FROM_NAME=AroTrade AI

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# ============================================================================
# SERVICES
# ============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Frontend
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_APP_NAME=AroTrade AI
NEXT_PUBLIC_BRAND_COLOR=#155DFC

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
ANALYTICS_ENABLED=false

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================

BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
#
# DOCKER COMPOSE (Local/VPS):
# 1. cp .env.example .env
# 2. Edit .env with your values
# 3. docker compose up -d
#
# GENERATE SECRETS (run locally):
# python3 -c "import secrets; print(secrets.token_hex(32))"
#
# CRITICAL SECURITY RULES:
# - NEVER commit .env to Git (it's in .gitignore)
# - NEVER hardcode passwords in code
# - NEVER share .env file
# - USE unique passwords for each environment
# - ROTATE secrets regularly
# - All secrets MUST be 20+ characters minimum
#
# ADMIN USER:
# After deployment, run: docker compose exec api python scripts/create_admin.py
# ============================================================================
