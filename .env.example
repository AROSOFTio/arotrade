# ============================================================================
# AroTrade AI - Environment Configuration Template
# Copy to .env and fill in with real values
# NEVER commit .env to Git - it contains secrets
# ============================================================================

# Application
APP_NAME=AroTrade AI
APP_ENV=production
APP_URL=https://arotrade.aroftlabs.com
DEBUG=false

# Database - PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=arotrade
POSTGRES_USER=arotrade
POSTGRES_PASSWORD=change_me_secure_password_here

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# Security - JWT
JWT_SECRET=change_me_very_secure_jwt_secret_min_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_DAYS=7

# Security - Encryption (32 character key for AES-256)
ENCRYPTION_KEY=change_me_32_character_encryption_key_here

# Security - Passwords
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# CORS & Security
ALLOWED_ORIGINS=https://arotrade.aroftlabs.com,http://localhost:3000
CORS_CREDENTIALS=true
RATE_LIMIT_PER_MINUTE=100

# ============================================================================
# AI PROVIDERS
# ============================================================================

# Gemini (Active)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Future AI Providers (Commented - uncomment when adding support)
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4-turbo
# GROQ_API_KEY=your_groq_key_here
# ANTHROPIC_API_KEY=your_claude_key_here
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=mistral

# ============================================================================
# TRADING INTEGRATIONS
# ============================================================================

# Demo Trading (Paper Engine)
DEMO_INITIAL_BALANCE=10000
DEMO_ACCOUNT_CURRENCY=USD

# Deriv API (Demo)
DERIV_APP_ID=
DERIV_API_TOKEN_DEMO=
DERIV_API_TOKEN_LIVE=
DERIV_SERVER_URL=wss://ws.derivws.com/websockets/v3

# Future Broker Integrations (Commented)
# METAAPI_TOKEN=your_metaapi_token
# METAAPI_ACCOUNT_ID=
# OANDA_API_KEY=your_oanda_key
# OANDA_ACCOUNT_ID=
# CTRADER_CLIENT_ID=
# CTRADER_CLIENT_SECRET=
# CTRADER_ACCOUNT_ID=
# TRADINGVIEW_WEBHOOK_SECRET=your_webhook_secret

# ============================================================================
# CRITICAL TRADING CONTROLS
# ============================================================================

# NEVER enable live trading without explicit admin action and user consent
ENABLE_LIVE_TRADING=false

# Risk Parameters (Defaults)
DEFAULT_RISK_PER_TRADE=1.0
MAX_RISK_PER_TRADE=5.0
MAX_DAILY_LOSS_PERCENT=3.0
MAX_WEEKLY_LOSS_PERCENT=5.0
MAX_OPEN_TRADES=5
MAX_ACCOUNT_DRAWDOWN_PERCENT=25.0

# Strategy Validation
MIN_BACKTEST_TRADES=100
MIN_PROFIT_FACTOR=1.2
MAX_CONSECUTIVE_LOSSES=5
ALLOW_MARTINGALE=false

# ============================================================================
# EMAIL (Optional - for notifications)
# ============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@arotrade.com
SMTP_FROM_NAME=AroTrade AI

# ============================================================================
# LOGGING
# ============================================================================

LOG_LEVEL=INFO
LOG_FORMAT=json
AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=90

# ============================================================================
# SERVICES
# ============================================================================

# API Server
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Frontend
NEXT_PUBLIC_API_URL=https://arotrade.aroftlabs.com/api
NEXT_PUBLIC_APP_NAME=AroTrade AI
NEXT_PUBLIC_BRAND_COLOR=#155DFC

# ============================================================================
# ADMIN
# ============================================================================

# Default admin email (set during initial setup)
ADMIN_EMAIL=admin@arotrade.com
ADMIN_PASSWORD=change_me_secure_password_here

# Feature Flags
FEATURE_LIVE_TRADING=false
FEATURE_MT5_BRIDGE=false
FEATURE_SOCIAL_SIGNALS=false
FEATURE_AI_OPTIMIZATION=false

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================

SENTRY_DSN=
SENTRY_ENVIRONMENT=production
ANALYTICS_ENABLED=false

# ============================================================================
# BACKUP & MAINTENANCE
# ============================================================================

BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30
