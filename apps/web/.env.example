# ============================================================================
# AroTrade AI - Frontend Environment Configuration
#
# Copy to .env.local (or .env for Coolify)
# Frontend variables MUST start with NEXT_PUBLIC_ (visible to browser)
# ============================================================================

# API Configuration
NEXT_PUBLIC_API_URL=https://arotrader.arosoftlabs.com/api
NEXT_PUBLIC_APP_NAME=AroTrade AI
NEXT_PUBLIC_BRAND_COLOR=#155DFC

# Feature Flags
NEXT_PUBLIC_ENABLE_DEMO=true
NEXT_PUBLIC_ENABLE_BACKTESTING=true
NEXT_PUBLIC_ENABLE_JOURNAL=true

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=

# ============================================================================
# NOTES:
# - All NEXT_PUBLIC_* variables are visible in browser (don't store secrets)
# - Update NEXT_PUBLIC_API_URL to your domain in production
# - Copy to .env.local for local development
# - Coolify injects these automatically
# ============================================================================
