# Frontend Environment Variables
# Copy to .env.local and update values

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_APP_NAME=AroTrade AI
NEXT_PUBLIC_BRAND_COLOR=#155DFC

# Feature Flags
NEXT_PUBLIC_ENABLE_DEMO=true
NEXT_PUBLIC_ENABLE_BACKTESTING=true
NEXT_PUBLIC_ENABLE_JOURNAL=true

# Analytics (Optional)
NEXT_PUBLIC_ANALYTICS_ID=
